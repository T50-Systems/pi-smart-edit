{
  "name": "@t50-systems/pi-smart-edit",
  "version": "0.2.0",
  "description": "Smart editing helpers for Pi with stale-anchor recovery and semantic patch workflows",
  "type": "module",
  "bin": {
    "pi-smart-edit": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "docs",
    "examples",
    "ARCHITECTURE.md",
    "VISION.md",
    "ROADMAP.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/test/**/*.test.js",
    "pretest": "npm run build",
    "coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-include=dist/src/**/*.js --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=80 dist/test/**/*.test.js",
    "benchmark": "npm run build && node dist/benchmark/smart-edit.bench.js",
    "verify:dependencies": "node scripts/verify-dependencies.mjs",
    "verify:policy": "node scripts/verify-repository-policy.mjs",
    "verify:workflows": "node scripts/verify-workflows.mjs",
    "verify:release": "npm run build && node scripts/verify-release.mjs"
  },
  "keywords": [
    "pi",
    "hashline",
    "editing",
    "stale-anchor",
    "tooling"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "T50-Systems",
  "dependencies": {
    "pi-anchor-edit-core": "github:T50-Systems/pi-anchor-edit-core#fa10abb76aee5e745ad291aff4448b09fd1cb47d",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "typescript": "^5.9.2",
    "yaml": "^2.8.3"
  },
  "pi": {
    "extensions": [
      "./dist/src/extension.js"
    ]
  }
}
