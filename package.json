{
  "name": "@t50-systems/pi-smart-edit",
  "version": "0.2.0",
  "description": "Smart editing helpers for Pi with stale-anchor recovery and semantic patch workflows",
  "type": "module",
  "bin": {
    "pi-smart-edit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/test/**/*.test.js",
    "pretest": "npm run build"
  },
  "keywords": [
    "pi",
    "hashline",
    "editing",
    "stale-anchor",
    "tooling"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "T50-Systems",
  "dependencies": {
    "pi-anchor-edit-core": "git+https://github.com/T50-Systems/pi-anchor-edit-core.git"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ]
  }
}
